// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "theme": "Gruvbox Dark Hard",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "tab_size": 2,
  "ui_font_size": 15,
  "buffer_font_size": 14,
  "buffer_font_family": "MonoLisa",
  "buffer_font_features": {
    "calt": true,
    "zero": true,
    "ss01": true
  },
  "autosave": "on_window_change",
  "language_overrides": {
    "Ruby": {
      "format_on_save": {
        "external": {
          "command": "stree",
          "arguments": ["format", "{buffer_path}"]
        }
      }
    }
  },
  "journal": {
    "path": "~",
    "hour_format": "hour24"
  },
  "terminal": {
    "copy_on_select": true,
    "dock": "right",
    "default_width": 500
  },
  "lsp": {
    "eslint": {
      "initialization_options": {
        "checkOnSave": {
          "command": "eslint"
        }
      },
      "probe": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "html",
        "json",
        "markdown",
        "ruby"
      ],
      "validate": [
        "javascript",
        "typescript",
        "javascriptreact",
        "ruby",
        "json"
      ]
    }
  }
}
